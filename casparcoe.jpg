@keyframes bounce {=20
  0% { left: 0px; z-index: 3; }
  5% { left: 0px; z-index: 3; }
  25% { left: 2px; z-index: 3; }
  50% { left: 5px; z-index: 3; }
  75% { left: 2px; z-index: 2; }
  95% { left: 0px; }
  100% { left: 0px; z-index: 2; }
}

@keyframes bounce-left {=20
  0% { left: 5px; }
  5% { left: 5px; }
  25% { left: 2px; }
  50% { left: 0px; }
  75% { left: 2px; }
  95% { left: 5px; }
  100% { left: 5px; }
}

