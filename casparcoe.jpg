s infinite normal none running pinkBall; border-radius: 100%; content: ""; =
height: 12px; position: absolute; top: 0px; width: 12px; }

.fluid .balls::before { background: rgb(255, 50, 156); left: 0px; }

.fluid .balls::after { animation: 1.6s ease-in-out 0s infinite normal none =
running blueBall; background: rgb(0, 99, 220); right: 0px; }

