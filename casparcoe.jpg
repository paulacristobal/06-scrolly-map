ition: absolute; width: 31px; z-index: 2147483646; }

.abgc { display: block; height: 15px; position: absolute; right: 1px; top: =
1px; text-rendering: geometricprecision; z-index: 2147483646; }

.abgb { display: inline-block; height: 15px; }

