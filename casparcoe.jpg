ent: ""; opacity: 0.8; position: absolute; transition: opacity 0.2s ease-in=
-out; z-index: 1; }

.cameraroll-zoom-modal .photo-container { left: 50%; opacity: 1; position: =
absolute; top: 50%; z-index: 2; }

