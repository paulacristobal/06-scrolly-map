ranslateX(-50%); width: 300px; }
}

.fluid-avatar-editor-view .zoom-controls { height: 15px; left: 34px; margin=
: 0px auto; opacity: 1; pointer-events: none; position: absolute; top: 16px=
; width: 360px; }

.fluid-avatar-editor-view .zoom-controls .zoom-handle { background-color: r=
gba(255, 255, 255, 0.95); border-radius: 18px; cursor: grab; height: 15px; =
left: 180px; pointer-events: auto; position: absolute; top: 0px; transition=
: none; width: 15px; z-index: 1; }

.fluid-avatar-editor-view .zoom-controls .zoom-handle.dragging { cursor: gr=
abbing; }

.fluid-avatar-editor-view .zoom-controls .zoom-guide { background-color: rg=
ba(255, 255, 255, 0.5); border-radius: 6px; height: 4px; position: relative=
; top: 5px; }

