@charset "utf-8";

@font-face { font-family: Proxima_Nova_Regular; src: url("https://consent.t=
rustarc.com/get?name=3Dproxima-nova-regular.woff") format("woff"); font-wei=
ght: normal; }

@font-face { font-family: Proxima_Nova_Bold; src: url("https://consent.trus=
tarc.com/get?name=3Dproxima-nova-bold.woff") format("woff"); font-weight: b=
old; }

#truste-consent-track { border: 1px solid rgb(151, 158, 162); padding: 10px=
 60px; font-family: Proxima_Nova_Regular, sans-serif; font-size: 12px; back=
ground: rgb(151, 158, 162); color: rgb(255, 255, 255); }

#truste-consent-text { color: rgb(255, 255, 255); }

#truste-consent-button { background-color: transparent; color: rgb(255, 255=
, 255); padding: 5px 10px; border: 1px solid rgb(255, 255, 255); border-rad=
ius: 2px; cursor: pointer; font-family: Proxima_Nova_Regular, sans-serif; }

#truste-ccpa-optout { background-color: transparent; color: rgb(255, 255, 2=
55); border: 1px solid rgb(255, 255, 255); padding: 5px 10px; border-radius=
: 2px; cursor: pointer; font-family: Proxima_Nova_Regular, sans-serif; }

#ccpa-no-preference { font-family: Proxima_Nova_Regular, sans-serif; color:=
 rgb(255, 255, 255); }

#truste-privacy-button { color: rgb(255, 255, 255); }

.truste-messageColumn { color: rgb(255, 255, 255); margin: 15px 0px; float:=
 left; }

.truste-buttonsColumn { float: right; margin: 10px 5px 10px 0px; }

.truste-buttonsColumn > button { height: 28px; }
