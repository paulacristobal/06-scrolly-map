  .fluid-avatar-editor-view .zoom-controls .zoom-handle { left: 50%; }
}

@keyframes pinkBall {=20
  0% { z-index: 1; }
  50% { transform: translateX(12px); }
}

@keyframes blueBall {=20
  50% { transform: translateX(-12px); }
}

.fluid .balls { display: inline-block; height: 12px; margin: 0px auto; posi=
tion: relative; width: 24px; }

.fluid .balls.block { display: block; }

